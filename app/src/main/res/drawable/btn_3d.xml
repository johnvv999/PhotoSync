<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed: flat and slightly darker, reads as "pushed in" since the raised bottom edge disappears -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="90"
                android:startColor="#1565C0"
                android:endColor="#1E88E5" />
            <stroke
                android:width="1dp"
                android:color="#0D47A1" />
        </shape>
    </item>
    <!-- Default: a darker base layer peeking out below a lighter top layer gives a raised, beveled look -->
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#0D47A1" />
                </shape>
            </item>
            <item android:bottom="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <gradient
                        android:angle="90"
                        android:startColor="#64B5F6"
                        android:endColor="#1E88E5" />
                    <stroke
                        android:width="1dp"
                        android:color="#0D47A1" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
